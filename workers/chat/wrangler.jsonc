{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "utrgpt-chat",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  // Native rate limiter: 10 requests / 60s per key (guest IP), period must be 10 or 60
  "ratelimits": [
    {
      "name": "GUEST_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 10, "period": 60 },
    },
    {
      // Per logged-in user: generous burst cap that blocks spam without affecting normal use.
      "name": "USER_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": { "limit": 20, "period": 60 },
    },
  ],
  "vars": {
    "ALLOWED_ORIGINS": "https://fortyai.vercel.app,https://utrgpt.vercel.app,http://localhost:3000",
    "MATCH_THRESHOLD": "0.5",
    // gemini-2.5-flash token rates ($/1M) + retail markup for debiting credits. Keep CREDIT_MARKUP synced with lib/credits.ts.
    "GEMINI_INPUT_USD_PER_1M": "0.3",
    "GEMINI_OUTPUT_USD_PER_1M": "2.5",
    "CREDIT_MARKUP": "4",
  },
}
