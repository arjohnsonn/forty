# Copy this file to `.env.local` and fill in your own values. NEVER commit `.env.local`.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API. The URL + anon key are PUBLIC (they ship to the browser);
# Row Level Security is your security boundary, so keep your policies tight.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role / secret key — SERVER ONLY, never expose. Used by account deletion
# and the Stripe webhook (both bypass RLS).
SUPABASE_SERVICE_ROLE_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini key (Google AI Studio). Used for embeddings + chat.
GOOGLE_GENERATIVE_AI_API_KEY=

# Deployed chat Worker URL, e.g. https://<name>.workers.dev (public).
NEXT_PUBLIC_CHAT_URL=

# ── Stripe (credit top-ups) ───────────────────────────────────────────────────
# Developers → API keys + Webhooks. Use sk_test_/test whsec_ locally,
# sk_live_/live whsec_ in production. The webhook adds the paid amount to the
# user's prepaid credit balance.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Chat Worker (workers/chat) ────────────────────────────────────────────────
# The Worker's NON-secret config lives in workers/chat/wrangler.jsonc (rates, markup).
# Its SECRETS are set with the Cloudflare CLI, not a file:
#   cd workers/chat
#   wrangler secret put SUPABASE_URL
#   wrangler secret put SUPABASE_ANON_KEY
#   wrangler secret put GOOGLE_GENERATIVE_AI_API_KEY
